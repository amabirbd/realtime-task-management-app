{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci && npm run build --workspace=@fredocloud/web"
  },
  "deploy": {
    "startCommand": "npm start --workspace=@fredocloud/web",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
